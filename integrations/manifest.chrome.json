{
  "manifest_version": 3,
  "permissions": [
    "tabs",
    "storage",
    "alarms"
  ],
  "host_permissions": [
    "http://127.0.0.1/*",
    "https://www.beamng.com/resources/*",
    "https://www.beamng.com/forums/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_title": "BeamNG-Manager Bridge",
    "default_popup": "popup.html"
  },
  "options_page": "options.html"
}
