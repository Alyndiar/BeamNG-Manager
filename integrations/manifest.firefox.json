{
  "manifest_version": 2,
  "permissions": [
    "tabs",
    "storage",
    "alarms",
    "http://127.0.0.1/*",
    "https://www.beamng.com/resources/*",
    "https://www.beamng.com/forums/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "browser_action": {
    "default_title": "BeamNG-Manager Bridge",
    "default_popup": "popup.html"
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "beamng-manager-bridge@local",
      "strict_min_version": "109.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
